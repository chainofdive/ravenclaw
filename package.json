{
  "name": "ravenclaw",
  "version": "0.1.0",
  "private": true,
  "description": "Personal work context management system for AI-powered development",
  "repository": {
    "type": "git",
    "url": "https://github.com/chainofdive/ravenclaw.git"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/chainofdive/ravenclaw",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "db:generate": "pnpm --filter @ravenclaw/core db:generate",
    "db:migrate": "pnpm --filter @ravenclaw/core db:migrate",
    "db:push": "pnpm --filter @ravenclaw/core db:push"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
